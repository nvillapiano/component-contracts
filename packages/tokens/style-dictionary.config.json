{
  "source": ["src/**/*.tokens.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "prefix": "ds",
      "buildPath": "dist/css/",
      "files": [
        {
          "destination": "tokens.css",
          "format": "css/variables",
          "options": {
            "selector": ":root",
            "outputReferences": true
          }
        }
      ]
    },
    "json": {
      "transformGroup": "js",
      "buildPath": "dist/json/",
      "files": [
        {
          "destination": "tokens.json",
          "format": "json/nested"
        }
      ]
    }
  }
}
