{
  "$schema": "../../schema/schema.json",
  "id": "button",
  "version": "2.0.0",
  "displayName": "Button",
  "description": "Triggers an action or event. The primary interactive element in the system.",
  "status": "stable",
  "platforms": ["web", "ios", "android"],
  "tokens": {
    "color": {
      "fill.brand":        "button.fill.brand",
      "fill.brand-hover":  "button.fill.brand-hover",
      "fill.brand-active": "button.fill.brand-active",
      "fill.danger":       "button.fill.danger",
      "fill.danger-hover": "button.fill.danger-hover",
      "fill.surface":      "button.fill.surface",
      "fill.muted":        "button.fill.muted",
      "text.inverse":      "button.text.inverse",
      "text.brand":        "button.text.brand",
      "border.brand":      "button.border.brand",
      "border.danger":     "button.border.danger",
      "border.danger-hover": "button.border.danger-hover",
      "focus.ring":        "button.focus.ring"
    },
    "typography": {
      "label.size.sm":  "button.typography.label-size-sm",
      "label.size.md":  "button.typography.label-size-md",
      "label.size.lg":  "button.typography.label-size-lg",
      "label.weight":   "button.typography.label-weight"
    },
    "spacing": {
      "padding.x.sm": "button.spacing.padding-x-sm",
      "padding.x.md": "button.spacing.padding-x-md",
      "padding.x.lg": "button.spacing.padding-x-lg",
      "padding.y.sm": "button.spacing.padding-y-sm",
      "padding.y.md": "button.spacing.padding-y-md",
      "padding.y.lg": "button.spacing.padding-y-lg",
      "icon.gap":     "button.spacing.icon-gap"
    },
    "border": {
      "radius": "button.border-radius",
      "width":  "button.border-width"
    },
    "motion": {
      "transition": "button.transition"
    }
  },
  "props": {
    "variant": {
      "type": "enum",
      "description": "Visual style of the button.",
      "values": ["primary", "secondary", "ghost", "destructive"],
      "default": "primary",
      "tokenMapped": true
    },
    "size": {
      "type": "enum",
      "description": "Controls padding and label size.",
      "values": ["sm", "md", "lg"],
      "default": "md",
      "tokenMapped": true
    },
    "label": {
      "type": "string",
      "description": "Visible button text.",
      "required": true
    },
    "disabled": {
      "type": "boolean",
      "description": "Prevents interaction.",
      "default": false
    },
    "loading": {
      "type": "boolean",
      "description": "Replaces label with a loading indicator.",
      "default": false
    },
    "iconStart": {
      "type": "ref",
      "ref": "icon",
      "description": "Icon rendered before the label.",
      "platforms": {
        "ios": { "supported": true, "nativeName": "leadingIcon" },
        "android": { "supported": true, "nativeName": "leadingIcon" }
      }
    },
    "iconEnd": {
      "type": "ref",
      "ref": "icon",
      "description": "Icon rendered after the label.",
      "platforms": {
        "ios": { "supported": true, "nativeName": "trailingIcon" },
        "android": { "supported": true, "nativeName": "trailingIcon" }
      }
    },
    "iconOnly": {
      "type": "boolean",
      "description": "Renders as a square icon button.",
      "default": false
    },
    "fullWidth": {
      "type": "boolean",
      "description": "Stretches button to fill its container.",
      "default": false,
      "platforms": {
        "ios": { "notes": "Use frame(maxWidth: .infinity) in SwiftUI." }
      }
    },
    "onPress": {
      "type": "function",
      "description": "Called when the button is activated.",
      "required": true
    },
    "href": {
      "type": "string",
      "description": "Renders as anchor tag on web.",
      "platforms": {
        "ios": { "supported": false },
        "android": { "supported": false }
      }
    },
    "type": {
      "type": "enum",
      "values": ["button", "submit", "reset"],
      "default": "button",
      "description": "HTML button type attribute.",
      "platforms": {
        "ios": { "supported": false },
        "android": { "supported": false }
      }
    }
  },
  "variants": [
    { "id": "primary-default", "displayName": "Primary", "props": { "variant": "primary", "size": "md", "label": "Continue" } },
    { "id": "secondary-default", "displayName": "Secondary", "props": { "variant": "secondary", "size": "md", "label": "Cancel" } },
    { "id": "ghost-default", "displayName": "Ghost", "props": { "variant": "ghost", "size": "md", "label": "More options" } },
    { "id": "destructive", "displayName": "Destructive", "description": "Always pair with a confirmation step.", "props": { "variant": "destructive", "size": "md", "label": "Delete" } },
    { "id": "icon-only", "displayName": "Icon Only", "props": { "variant": "ghost", "size": "md", "iconOnly": true, "label": "Close" } },
    { "id": "loading", "displayName": "Loading", "props": { "variant": "primary", "size": "md", "label": "Saving", "loading": true } }
  ],
  "states": ["default", "hover", "focus", "active", "disabled", "loading"],
  "behavior": {
    "focusable": true,
    "pressable": true,
    "keyboardShortcuts": [
      { "key": "Enter", "action": "Activate button" },
      { "key": "Space", "action": "Activate button" }
    ]
  },
  "accessibility": {
    "role": "button",
    "labelSource": "prop",
    "focusManagement": "self",
    "wcagLevel": "AA"
  },
  "composition": {
    "slots": {},
    "forbiddenParents": ["button"]
  },
  "usage": {
    "summary": "Use Button to trigger actions. Choose variant based on action priority.",
    "do": [
      "Use one primary button per section or modal",
      "Keep labels short and action-oriented",
      "Use loading state to prevent duplicate submissions"
    ],
    "dont": [
      "Don't use more than one primary button in a single context",
      "Don't use for navigation — use a Link instead",
      "Don't nest buttons inside other interactive elements"
    ],
    "relatedComponents": ["icon-button", "link", "menu-trigger"]
  },
  "platformNotes": {
    "ios": "Use ButtonStyle protocol for variant theming. Loading state should use ProgressView overlay.",
    "android": "Implement as Material3 Button with custom ColorScheme. Use CircularProgressIndicator for loading."
  },
  "changelog": [
    {
      "version": "2.0.0",
      "date": "2025-01-15",
      "changes": [
        "BREAKING: Renamed 'danger' variant to 'destructive'",
        "Added 'loading' prop",
        "Added iconStart/iconEnd props"
      ]
    },
    {
      "version": "1.0.0",
      "date": "2024-04-10",
      "changes": ["Initial stable release"]
    }
  ]
}
