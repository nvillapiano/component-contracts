# Figma file keys for component-contracts
# Copy this file to .figma and fill in your values
# Never commit .figma — it contains project-specific identifiers

FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
TOKENS_DIR=
CONTRACTS_DIR=


# for example
FIGMA_ACCESS_TOKEN=figd_<huge-long-token> # generate a Figma API key https://developers.figma.com/docs/rest-api/authentication/
FIGMA_FILE_KEY=https://www.figma.com/file/<FILE_KEY>/File-Name # grab the file key from the Figma file URL
TOKENS_DIR=packages/tokens/src # the directory where the tokens are stored
CONTRACTS_DIR=i.e.packages/contracts/src # the directory where the contracts are stored

