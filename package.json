{
  "name": "component-contracts",
  "version": "0.0.1",
  "private": true,
  "description": "Design system component contract repository",
  "scripts": {
    "build": "pnpm -r build",
    "dev:mcp": "pnpm --filter @ds/mcp-server dev",
    "dev:web": "pnpm --filter @ds/web dev",
    "kill:web": "lsof -ti :6006 | xargs kill 2>/dev/null || true",
    "reset:web": "pnpm run kill:web ; pnpm run dev:web",
    "dev:tokens": "pnpm --filter @ds/tokens dev",
    "validate": "pnpm --filter @ds/validator start",
    "types:generate": "pnpm --filter @ds/schema generate",
    "tokens:build": "pnpm --filter @ds/tokens build",
    "test": "pnpm --filter @ds/web test",
    "test:ci": "pnpm --filter @ds/web test:ci"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
