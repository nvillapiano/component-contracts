# Optional: override project root for the MCP server when it's not run from the repo root.
# Uncomment and set if you need an absolute path (e.g. in a custom Cursor/CI setup).
# COMPONENT_CONTRACTS_ROOT=/absolute/path/to/component-contracts

# Optional: override contracts directory (resolved relative to COMPONENT_CONTRACTS_ROOT or cwd).
# Default in .cursor/mcp.json is "packages/contracts/src".
# CONTRACTS_DIR=packages/contracts/src
